@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Nav
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar

<AuthorizeView>
    <Authorized>
        <MudLayout>
            <MudAppBar Elevation="0" Fixed> 
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                               OnClick="ToggleDrawer" />
                <MudSpacer />
                <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                         Icon="@Icons.Material.Filled.Person">
                    @Auth.DisplayName
                </MudChip>
                <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="LogoutAsync"
                               Size="Size.Small" />
            </MudAppBar>

            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always">
                <div class="nav-brand">
                    <div class="nav-brand-title">LoreLoom</div>
                    <div class="nav-brand-subtitle">Tabletop RPG</div>
                </div>
                <MudNavMenu>
                    <MudNavLink Href="/games" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.SportsEsports">Games</MudNavLink>
                    <MudNavLink Href="/games/create" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Add">Create Game</MudNavLink>
                    <MudNavLink Href="/characters" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.People">Characters</MudNavLink>
                    <MudNavLink Href="/ranking" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.EmojiEvents">Ranking</MudNavLink>
                    <MudDivider Class="my-2 mx-4" Style="border-color:rgba(255,255,255,0.06);" />
                    <MudNavLink Href="/profile" Match="NavLinkMatch.All"
                                Icon="@Icons.Material.Filled.Person">Profile</MudNavLink>
                </MudNavMenu>
            </MudDrawer>

            @if (!Auth.EmailVerified)
            {
                <MudAlert Severity="Severity.Warning" Class="mx-4 mt-2" Dense="true" ShowCloseIcon="false">
                    Your email is not verified. Check your inbox or
                    <MudLink OnClick="ResendVerificationAsync" Color="Color.Warning" Style="cursor:pointer;text-decoration:underline;">
                        resend verification email
                    </MudLink>.
                </MudAlert>
            }

            <MudMainContent Class="layout-content pa-6" Style="min-height:100vh;">
                @Body
            </MudMainContent>
        </MudLayout>
    </Authorized>

    <NotAuthorized>
        @Body
    </NotAuthorized>
</AuthorizeView>

@code {
    private bool _drawerOpen = true;

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task LogoutAsync()
    {
        await Auth.LogoutAsync();
        Nav.NavigateTo("/");
    }

    private async Task ResendVerificationAsync()
    {
        try
        {
            await Api.ResendVerificationAsync();
            Snackbar.Add("Verification email sent. Check your inbox.", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Could not send verification email.", Severity.Error);
        }
    }
}
