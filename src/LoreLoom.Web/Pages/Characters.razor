@page "/characters"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject ISnackbar Snackbar

<div class="d-flex align-center justify-space-between flex-wrap gap-4 mb-6">
    <MudText Typo="Typo.h4">My Characters</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               OnClick="() => _showCreate = true" StartIcon="@Icons.Material.Filled.Add"
               Style="border-radius:12px;">
        Create Character
    </MudButton>
</div>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_characters.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        You don't have any characters yet. Create one to get started!
    </MudAlert>
}
else
{
    <MudGrid>
        @foreach (var c in _characters)
        {
            <MudItem xs="12" sm="6" md="4">
                <MudCard Elevation="0" Class="glass-card">
                    <MudCardHeader>
                        <MudText Typo="Typo.h6">@c.Name</MudText>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (!string.IsNullOrEmpty(c.Backstory))
                        {
                            <MudText Typo="Typo.body2" Class="mb-3" Style="color:#9A97B0;font-style:italic;">
                                @c.Backstory
                            </MudText>
                        }
                        <div class="d-flex gap-2 mb-3">
                            <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled"
                                     Class="stat-chip">STR @c.Strength</MudChip>
                            <MudChip T="string" Color="Color.Info" Size="Size.Small" Variant="Variant.Filled"
                                     Class="stat-chip">WIT @c.Wit</MudChip>
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled"
                                     Class="stat-chip">CHA @c.Charisma</MudChip>
                        </div>
                        <div class="d-flex align-center gap-2 mb-1">
                            <MudText Typo="Typo.body2" Style="color:#9A97B0;">
                                Level @c.Level
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:#9A97B0;">
                                @c.Xp / @(c.Xp + c.XpToNextLevel) XP
                            </MudText>
                        </div>
                        <MudProgressLinear Value="@GetXpPercent(c)" Color="Color.Secondary" Class="mt-1"
                                           Style="border-radius:4px;" />
                    </MudCardContent>
                </MudCard>
            </MudItem>
        }
    </MudGrid>
}

@* Create Character Dialog *@
<MudDialog @bind-Visible="_showCreate">
    <TitleContent>
        <MudText Typo="Typo.h6">Create Character</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newName" Label="Name" Variant="Variant.Outlined" Class="mb-4"
                      Required="true" MaxLength="100"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge" />
        <MudTextField @bind-Value="_newBackstory" Label="Backstory (optional)" Variant="Variant.Outlined"
                      Class="mb-4" Lines="3" />

        <MudText Typo="Typo.subtitle2" Class="mb-3">
            Stats — must sum to 9, each 1-5:
            <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                     Color="@(_newStr + _newWit + _newCha == 9 ? Color.Success : Color.Error)">
                @(_newStr + _newWit + _newCha)/9
            </MudChip>
        </MudText>
        <MudSlider @bind-Value="_newStr" Min="1" Max="5" Step="1" Color="Color.Error" Class="mb-2">
            Strength: @_newStr
        </MudSlider>
        <MudSlider @bind-Value="_newWit" Min="1" Max="5" Step="1" Color="Color.Info" Class="mb-2">
            Wit: @_newWit
        </MudSlider>
        <MudSlider @bind-Value="_newCha" Min="1" Max="5" Step="1" Color="Color.Warning" Class="mb-2">
            Charisma: @_newCha
        </MudSlider>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showCreate = false">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateCharacterAsync"
                   Disabled="@(_newStr + _newWit + _newCha != 9 || string.IsNullOrWhiteSpace(_newName))"
                   Style="border-radius:10px;">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CharacterResponse> _characters = [];
    private bool _loading = true;
    private bool _showCreate;

    private string _newName = "";
    private string _newBackstory = "";
    private int _newStr = 3;
    private int _newWit = 3;
    private int _newCha = 3;

    protected override async Task OnInitializedAsync()
    {
        await LoadCharactersAsync();
    }

    private async Task LoadCharactersAsync()
    {
        _loading = true;
        try
        {
            _characters = await Api.GetMyCharactersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading characters: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateCharacterAsync()
    {
        try
        {
            var request = new CreateCharacterRequest(
                Auth.AccountToken ?? "", _newName, _newBackstory, _newStr, _newWit, _newCha);
            await Api.CreateCharacterAsync(request);
            Snackbar.Add($"{_newName} created!", Severity.Success);
            _showCreate = false;
            _newName = "";
            _newBackstory = "";
            _newStr = _newWit = _newCha = 3;
            await LoadCharactersAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private static double GetXpPercent(CharacterResponse c) =>
        c.Xp + c.XpToNextLevel == 0 ? 0 : (double)c.Xp / (c.Xp + c.XpToNextLevel) * 100;
}
