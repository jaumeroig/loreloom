@page "/games/create"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T

<MudText Typo="Typo.h4" Class="mb-6">@T["create_game_title"]</MudText>

<MudGrid>
    <MudItem xs="12" md="8">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudTextField @bind-Value="_title" Label="@(T["create_game_title_label"])" Variant="Variant.Outlined"
                              Class="mb-4" Required="true" MaxLength="200"
                              Placeholder="@(T["create_game_title_placeholder"])"/>

                <MudTextField @bind-Value="_setting" Label="@(T["create_game_setting_label"])"
                              Variant="Variant.Outlined" Class="mb-4" Required="true" Lines="4"
                              Placeholder="@(T["create_game_setting_placeholder"])" />

                <MudTextField @bind-Value="_resourceName" Label="@(T["create_game_resource_label"])"
                              Variant="Variant.Outlined" Class="mb-4" Required="true" MaxLength="200"
                              Placeholder="@(T["create_game_resource_placeholder"])"
                              HelperText="@(T["create_game_resource_helper"])"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Favorite" />

                <MudNumericField @bind-Value="_maxPlayers" Label="@(T["create_game_max_players"])" Variant="Variant.Outlined"
                                  Class="mb-4" Min="1" Max="8"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Group" />

                <MudSwitch @bind-Value="_isPublic" Color="Color.Primary" Class="mb-4"
                           Label="@(_isPublic ? T["create_game_public"] : T["create_game_private"])" />

                <MudSelect T="string" @bind-Value="_language" Label="@(T["create_game_language"])"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Language">
                    <MudSelectItem Value="@AppCultures.Catalan">@T["culture_ca-ES"]</MudSelectItem>
                    <MudSelectItem Value="@AppCultures.Spanish">@T["culture_es-ES"]</MudSelectItem>
                    <MudSelectItem Value="@AppCultures.English">@T["culture_en-US"]</MudSelectItem>
                </MudSelect>
            </MudCardContent>
            <MudCardActions Class="pa-5 pt-0">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="CreateAsync"
                           Disabled="@(!IsValid || _loading)" StartIcon="@Icons.Material.Filled.Add"
                           Style="border-radius:12px;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @T["create_game_button"]
                </MudButton>
            </MudCardActions>
        </MudCard>
    </MudItem>

    <MudItem xs="12" md="4">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-2">@T["create_game_character_title"]</MudText>
                <MudText Typo="Typo.body2" Class="mb-4" Style="color:#9A97B0;">
                    @T["create_game_character_help"]
                </MudText>
                @if (_characters.Count > 0)
                {
                    <MudSelect T="Guid?" @bind-Value="_selectedCharacterId" Label="@(T["create_game_character_label"])"
                               Variant="Variant.Outlined" Clearable="true"
                               AnchorOrigin="Origin.BottomCenter"
                               Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person">
                        @foreach (var c in _characters)
                        {
                            <MudSelectItem T="Guid?" Value="@c.Id">@c.Name (Lv.@c.Level)</MudSelectItem>
                        }
                    </MudSelect>
                }
                else
                {
                    <MudAlert Severity="Severity.Info" Dense="true" Variant="Variant.Outlined">
                        @T["create_game_no_characters"] <MudLink Href="/characters" Color="Color.Secondary">@T["create_game_create_character"]</MudLink>
                    </MudAlert>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _title = "";
    private string _setting = "";
    private string _resourceName = "Hope";
    private int _maxPlayers = 4;
    private bool _isPublic = true;
    private string _language = AppCultures.DefaultCulture;
    private Guid? _selectedCharacterId;
    private List<CharacterResponse> _characters = [];
    private bool _loading;

    private bool IsValid => !string.IsNullOrWhiteSpace(_title)
                         && !string.IsNullOrWhiteSpace(_setting)
                         && !string.IsNullOrWhiteSpace(_resourceName);

    protected override async Task OnInitializedAsync()
    {
        _language = Auth.Language;
        try { _characters = await Api.GetMyCharactersAsync(); }
        catch { /* characters are optional */ }
    }

    private async Task CreateAsync()
    {
        _loading = true;
        try
        {
            var request = new CreateGameRequest(
                _title, _setting, _resourceName,
                Auth.AccountToken ?? "", Auth.DisplayName ?? "",
                _selectedCharacterId, _isPublic, _maxPlayers, _language);
            var game = await Api.CreateGameAsync(request);
            if (game is not null)
            {
                Snackbar.Add(T["create_game_created"], Severity.Success);
                Nav.NavigateTo($"/games/{game.Id}/lobby");
            }
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _loading = false; }
    }
}
