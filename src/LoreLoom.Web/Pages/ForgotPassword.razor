@page "/forgot-password"
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar

<div class="hero-section">
    <MudCard Class="auth-card" Style="width: 420px; max-width: 95vw;">
        <MudCardContent Class="pa-6">
            <div class="text-center mb-6">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="letter-spacing:0.04em;">LoreLoom</MudText>
                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mt-1">Reset your password</MudText>
            </div>

            @if (_sent)
            {
                <MudAlert Severity="Severity.Info" Class="mb-2">
                    If that email is registered, we've sent a reset link. Check your inbox (and spam folder).
                </MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           Href="/login" Style="border-radius:12px;margin-top:8px;">
                    Back to Login
                </MudButton>
            }
            else
            {
                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mb-4">
                    Enter your email and we'll send you a link to reset your password.
                </MudText>
                <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-4" Required="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                              OnKeyDown="OnKeyDown" />
            }
        </MudCardContent>

        @if (!_sent)
        {
            <MudCardActions Class="d-flex flex-column pa-6 pt-0">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="SendResetAsync" Disabled="_loading"
                           Style="border-radius:12px;height:48px;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Send Reset Link
                </MudButton>
                <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center" Style="color:#9A97B0;">
                    Remember your password?
                    <MudLink Href="/login" Color="Color.Secondary">Log in</MudLink>
                </MudText>
            </MudCardActions>
        }
    </MudCard>
</div>

@code {
    private string _email = "";
    private bool _loading;
    private bool _sent;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await SendResetAsync();
    }

    private async Task SendResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_email))
        {
            Snackbar.Add("Please enter your email.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            await Api.ForgotPasswordAsync(new ForgotPasswordRequest(_email));
            _sent = true;
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
