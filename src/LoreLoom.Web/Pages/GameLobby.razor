@page "/games/{GameId:guid}/lobby"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-6">@T["lobby_title"]</MudText>

@if (_game is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="0" Class="glass-card">
                <MudCardHeader>
                    <MudText Typo="Typo.h5">@_game.Title</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body1" Class="mb-4" Style="color:#9A97B0;line-height:1.6;">
                        @_game.Setting
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:#9A97B0;">
                        @T.Format("lobby_players_count", _game.PlayerCount, _game.MaxPlayers)
                    </MudText>

                    <MudList T="string" Dense="true">
                        @foreach (var p in _game.Players)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                <div class="d-flex align-center gap-2">
                                    <MudText>@p.Name</MudText>
                                    @if (p.IsCreator)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                                 Variant="Variant.Text">@T["lobby_creator"]</MudChip>
                                    }
                                </div>
                            </MudListItem>
                        }
                    </MudList>

                    @if (!_game.IsPublic && _game.InviteCode is not null)
                    {
                        <div class="mt-4 pa-4" style="background:rgba(240,185,82,0.04);border-radius:12px;text-align:center;">
                            <MudText Typo="Typo.caption" Style="color:#9A97B0;letter-spacing:0.1em;text-transform:uppercase;" Class="mb-2">
                                @T["lobby_invite_code"]
                            </MudText>
                            <div class="invite-code">@_game.InviteCode</div>
                            <MudText Typo="Typo.caption" Style="color:#9A97B0;" Class="mt-2">
                                @T["lobby_share_invite"]
                            </MudText>
                        </div>
                    }

                    @if (_game.Status == GameStatus.Active)
                    {
                        <MudAlert Severity="Severity.Success" Class="mt-4" Variant="Variant.Outlined">
                            @T["lobby_started"]
                        </MudAlert>
                    }
                </MudCardContent>
                <MudCardActions Class="pa-4">
                    @if (IsCreator && _game.Status == GameStatus.Waiting)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartGameAsync"
                                   Disabled="_starting" StartIcon="@Icons.Material.Filled.PlayArrow"
                                   Style="border-radius:12px;">
                            @if (_starting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            @T["lobby_start_game"]
                        </MudButton>
                        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="OpenDeleteDialog"
                                    Disabled="_deleting" StartIcon="@Icons.Material.Filled.DeleteOutline">
                            @T["lobby_delete_game"]
                        </MudButton>
                    }
                    else if (_game.Status == GameStatus.Waiting)
                    {
                        <MudText Typo="Typo.body2" Style="color:#9A97B0;">
                            @T["lobby_waiting_creator"]
                        </MudText>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}

<MudDialog @bind-Visible="_showDeleteDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@T["games_delete_title"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            @T.Format("games_delete_confirmation", _game?.Title ?? string.Empty)
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">@T["common_cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteGameAsync"
                   Disabled="_deleting" Style="border-radius:10px;">
            @T["common_delete"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [Parameter] public Guid GameId { get; set; }

    private GameResponse? _game;
    private bool _starting;
    private bool _deleting;
    private bool _showDeleteDialog;
    private Timer? _pollTimer;

    private bool IsCreator => _game?.IsOwnedByCurrentUser == true;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _pollTimer = new Timer(async _ =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }, null, 3000, 3000);
    }

    private async Task RefreshAsync()
    {
        try
        {
            _game = await Api.GetGameAsync(GameId);
            if (_game?.Status == GameStatus.Active)
            {
                _pollTimer?.Dispose();
                Nav.NavigateTo($"/games/{GameId}");
            }
        }
        catch { /* ignore polling errors */ }
    }

    private async Task StartGameAsync()
    {
        _starting = true;
        try
        {
            var request = new StartGameRequest(Auth.AccountToken ?? "", Auth.Language);
            await Api.StartGameAsync(GameId, request);
            Nav.NavigateTo($"/games/{GameId}");
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _starting = false; }
    }

    private async Task DeleteGameAsync()
    {
        _deleting = true;
        try
        {
            await Api.DeleteGameAsync(GameId);
            CloseDeleteDialog();
            Snackbar.Add(T["games_deleted"], Severity.Success);
            Nav.NavigateTo("/games");
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _deleting = false; }
    }

    private void OpenDeleteDialog() => _showDeleteDialog = true;

    private void CloseDeleteDialog() => _showDeleteDialog = false;

    public void Dispose() => _pollTimer?.Dispose();
}
