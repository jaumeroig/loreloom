@page "/games/{GameId:guid}/lobby"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@implements IDisposable

<MudText Typo="Typo.h4" Class="mb-6">Game Lobby</MudText>

@if (_game is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudGrid>
        <MudItem xs="12" md="8">
            <MudCard Elevation="0" Class="glass-card">
                <MudCardHeader>
                    <MudText Typo="Typo.h5">@_game.Title</MudText>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body1" Class="mb-4" Style="color:#9A97B0;line-height:1.6;">
                        @_game.Setting
                    </MudText>

                    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="color:#9A97B0;">
                        Players (@_game.PlayerCount / @_game.MaxPlayers)
                    </MudText>

                    <MudList T="string" Dense="true">
                        @foreach (var p in _game.Players)
                        {
                            <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                <div class="d-flex align-center gap-2">
                                    <MudText>@p.Name</MudText>
                                    @if (p.IsCurrentTurn)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                                 Variant="Variant.Text">Creator</MudChip>
                                    }
                                </div>
                            </MudListItem>
                        }
                    </MudList>

                    @if (!_game.IsPublic && _game.InviteCode is not null)
                    {
                        <div class="mt-4 pa-4" style="background:rgba(240,185,82,0.04);border-radius:12px;text-align:center;">
                            <MudText Typo="Typo.caption" Style="color:#9A97B0;letter-spacing:0.1em;text-transform:uppercase;" Class="mb-2">
                                Invite Code
                            </MudText>
                            <div class="invite-code">@_game.InviteCode</div>
                            <MudText Typo="Typo.caption" Style="color:#9A97B0;" Class="mt-2">
                                Share this with friends to let them join
                            </MudText>
                        </div>
                    }

                    @if (_game.Status == GameStatus.Active)
                    {
                        <MudAlert Severity="Severity.Success" Class="mt-4" Variant="Variant.Outlined">
                            Game has started!
                        </MudAlert>
                    }
                </MudCardContent>
                <MudCardActions Class="pa-4">
                    @if (IsCreator && _game.Status == GameStatus.Waiting)
                    {
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="StartGameAsync"
                                   Disabled="_starting" StartIcon="@Icons.Material.Filled.PlayArrow"
                                   Style="border-radius:12px;">
                            @if (_starting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                            Start Game
                        </MudButton>
                    }
                    else if (_game.Status == GameStatus.Waiting)
                    {
                        <MudText Typo="Typo.body2" Style="color:#9A97B0;">
                            Waiting for the creator to start the game...
                        </MudText>
                    }
                </MudCardActions>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public Guid GameId { get; set; }

    private GameResponse? _game;
    private bool _starting;
    private Timer? _pollTimer;

    private bool IsCreator => _game?.Players.FirstOrDefault(p => p.IsCurrentTurn)?.Name == Auth.DisplayName;

    protected override async Task OnInitializedAsync()
    {
        await RefreshAsync();
        _pollTimer = new Timer(async _ =>
        {
            await RefreshAsync();
            await InvokeAsync(StateHasChanged);
        }, null, 3000, 3000);
    }

    private async Task RefreshAsync()
    {
        try
        {
            _game = await Api.GetGameAsync(GameId);
            if (_game?.Status == GameStatus.Active)
            {
                _pollTimer?.Dispose();
                Nav.NavigateTo($"/games/{GameId}");
            }
        }
        catch { /* ignore polling errors */ }
    }

    private async Task StartGameAsync()
    {
        _starting = true;
        try
        {
            var request = new StartGameRequest(Auth.AccountToken ?? "", Auth.Language);
            await Api.StartGameAsync(GameId, request);
            Nav.NavigateTo($"/games/{GameId}");
        }
        catch (Exception ex) { Snackbar.Add($"Error: {ex.Message}", Severity.Error); }
        finally { _starting = false; }
    }

    public void Dispose() => _pollTimer?.Dispose();
}
