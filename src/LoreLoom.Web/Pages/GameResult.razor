@page "/games/{GameId:guid}/result"
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar
@inject IJSRuntime Js
@inject IAppTextLocalizer T

<MudText Typo="Typo.h4" Class="mb-6">@T["result_title"]</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_result is null)
{
    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">@T["result_not_available"]</MudAlert>
}
else
{
    <MudCard Elevation="0" Class="glass-card mb-4">
        <MudCardHeader>
            <div>
                <MudText Typo="Typo.h5" Color="@(_result.Victory ? Color.Success : Color.Error)">
                    @(_result.Victory ? T["gameplay_victory"] : T["gameplay_defeat"])
                </MudText>
                <MudText Typo="Typo.subtitle1" Style="color:#9A97B0;">@_result.GameTitle</MudText>
            </div>
        </MudCardHeader>
        <MudCardContent>
            @if (!string.IsNullOrEmpty(_result.Postmortem))
            {
                <MudCard Elevation="0" Class="mb-5 pa-4"
                         Style="background:rgba(179,136,255,0.04);border:1px solid rgba(179,136,255,0.1);border-radius:12px;">
                    <MudText Typo="Typo.caption" Color="Color.Secondary"
                             Style="font-weight:600;letter-spacing:0.1em;text-transform:uppercase;" Class="mb-2">
                        @T["result_chronicle"]
                    </MudText>
                    <MudText Typo="Typo.body1" Style="color:#9A97B0;font-style:italic;line-height:1.7;">
                        @_result.Postmortem
                    </MudText>
                </MudCard>
            }

            <MudTable Items="_result.Players" Hover="true" Elevation="0"
                      Style="background:transparent;">
                <HeaderContent>
                    <MudTh>@T["result_player"]</MudTh>
                    <MudTh>@T["result_character"]</MudTh>
                    <MudTh>@T["result_level"]</MudTh>
                    <MudTh>@T["result_xp_earned"]</MudTh>
                    <MudTh>@T["result_points"]</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd><b>@context.Name</b></MudTd>
                    <MudTd>@(context.CharacterName ?? "—")</MudTd>
                    <MudTd>@(context.CharacterLevel?.ToString() ?? "—")</MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                            @T.Format("result_xp_value", context.XpEarned)
                        </MudChip>
                    </MudTd>
                    <MudTd>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Text">
                            @T.Format("result_points_value", context.PointsEarned)
                        </MudChip>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </MudCardContent>
        <MudCardActions Class="pa-4 d-flex gap-3">
            <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ExportAsync"
                       StartIcon="@Icons.Material.Filled.Download" Style="border-radius:12px;">
                @T["result_export"]
            </MudButton>
            <MudButton Variant="Variant.Text" Href="/games" Style="color:#9A97B0;">
                @T["result_back_to_games"]
            </MudButton>
        </MudCardActions>
    </MudCard>
}

@code {
    [Parameter] public Guid GameId { get; set; }

    private GameResultResponse? _result;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _result = await Api.GetResultAsync(GameId); }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _loading = false; }
    }

    private async Task ExportAsync()
    {
        try
        {
            var markdown = await Api.ExportGameAsync(GameId);
            if (markdown is null) { Snackbar.Add(T["result_export_unavailable"], Severity.Warning); return; }

            var bytes = System.Text.Encoding.UTF8.GetBytes(markdown);
            var base64 = Convert.ToBase64String(bytes);
            var fileName = $"loreloom-{_result?.GameTitle?.Replace(" ", "-").ToLower() ?? GameId.ToString()[..8]}.md";
            await Js.InvokeVoidAsync("eval",
                $"var a=document.createElement('a');a.href='data:text/markdown;base64,{base64}';a.download='{fileName}';a.click();");
            Snackbar.Add(T["result_exported"], Severity.Success);
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
    }
}
