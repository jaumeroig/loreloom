@page "/games"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T

<div class="d-flex align-center justify-space-between flex-wrap gap-4 mb-6">
    <MudText Typo="Typo.h4">@T["games_title"]</MudText>
    <div class="d-flex gap-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/games/create"
                   StartIcon="@Icons.Material.Filled.Add" Style="border-radius:12px;">
            @T["games_create"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" OnClick="ShowJoinByCode"
                   StartIcon="@Icons.Material.Filled.VpnKey" Style="border-radius:12px;">
            @T["games_join_by_code"]
        </MudButton>
    </div>
</div>

<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" Class="mb-4"
         PanelClass="pt-4">
    <MudTabPanel Text="@T["games_open_games"]" Icon="@Icons.Material.Filled.Public">
        @if (_loadingOpen)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
        }
        else if (_openGames.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-2" Variant="Variant.Outlined">
                @T["games_no_open_games"]
            </MudAlert>
        }
        else
        {
            <MudGrid Class="mt-2">
                @foreach (var g in _openGames)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Class="glass-card">
                            <MudCardHeader>
                                <MudText Typo="Typo.h6">@g.Title</MudText>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mb-3">@g.Setting</MudText>
                                <div class="d-flex gap-2 flex-wrap mb-2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                                        @T.Format("games_players_count", g.PlayerCount, g.MaxPlayers)
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Text">
                                        @g.ResourceName
                                    </MudChip>
                                </div>
                            </MudCardContent>
                            <MudCardActions>
                                @if (g.Players.Any(p => p.Name == Auth.DisplayName))
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Primary"
                                               OnClick="() => GoToGame(g)">
                                        @T["games_continue"]
                                    </MudButton>
                                }
                                else if (g.PlayerCount < g.MaxPlayers)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                               OnClick="() => JoinGameAsync(g.Id)"
                                               Style="border-radius:10px;">
                                        @T["common_join"]
                                    </MudButton>
                                }
                                else
                                {
                                    <MudChip T="string" Size="Size.Small" Color="Color.Default">@T["games_full"]</MudChip>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>

    <MudTabPanel Text="@T["games_my_active_games"]" Icon="@Icons.Material.Filled.Gamepad">
        @if (_loadingActive)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
        }
        else if (_myActiveGames.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Class="mt-2" Variant="Variant.Outlined">
                @T["games_no_active_games"]
            </MudAlert>
        }
        else
        {
            <MudGrid Class="mt-2">
                @foreach (var g in _myActiveGames)
                {
                    <MudItem xs="12" sm="6" md="4">
                        <MudCard Elevation="0" Class="glass-card">
                            <MudCardHeader>
                                <MudText Typo="Typo.h6">@g.Title</MudText>
                            </MudCardHeader>
                            <MudCardContent>
                                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mb-3">@g.Setting</MudText>
                                <div class="d-flex gap-2 flex-wrap mb-2">
                                    <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Text">
                                        @T.Format("games_players_only", g.PlayerCount)
                                    </MudChip>
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text"
                                             Color="@(g.Status == GameStatus.Active ? Color.Success : Color.Default)">
                                        @g.Status
                                    </MudChip>
                                </div>
                                @if (g.Status == GameStatus.Active)
                                {
                                    <div class="resource-bar mt-2">
                                        <div class="resource-bar-fill"
                                             style="width:@(g.ResourcePct)%;background-color:@ResourceColorHex(g.ResourcePct);">
                                        </div>
                                    </div>
                                    <MudText Typo="Typo.caption" Style="color:#9A97B0;" Class="mt-1">
                                        @g.ResourceName: @g.ResourcePct%
                                    </MudText>
                                }
                            </MudCardContent>
                            <MudCardActions>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                                           OnClick="() => GoToGame(g)" Style="border-radius:10px;">
                                    @(g.Status == GameStatus.Active ? T["games_play"] : g.Status == GameStatus.Finished ? T["games_results"] : T["games_lobby"])
                                </MudButton>
                                @if (g.IsOwnedByCurrentUser)
                                {
                                    <MudButton Variant="Variant.Text" Color="Color.Error"
                                               OnClick="() => ConfirmDelete(g)"
                                               StartIcon="@Icons.Material.Filled.DeleteOutline">
                                        @T["common_delete"]
                                    </MudButton>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>
</MudTabs>

@* Join by Invite Code Dialog *@
<MudDialog @bind-Visible="_showJoinByCode">
    <TitleContent>
        <MudText Typo="Typo.h6">@T["games_join_dialog_title"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_inviteCode" Label="@(T["games_invite_code"])" Variant="Variant.Outlined"
                      Placeholder="@(T["games_invite_code_placeholder"])"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.VpnKey" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _showJoinByCode = false">@T["common_cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="JoinByCodeAsync"
                   Disabled="@string.IsNullOrWhiteSpace(_inviteCode)" Style="border-radius:10px;">
            @T["common_join"]
        </MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_showDeleteDialog">
    <TitleContent>
        <MudText Typo="Typo.h6">@T["games_delete_title"]</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            @T.Format("games_delete_confirmation", _gameToDelete?.Title ?? string.Empty)
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CloseDeleteDialog">@T["common_cancel"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DeleteGameAsync"
                   Disabled="@(_deletingGame || _gameToDelete is null)" Style="border-radius:10px;">
            @T["common_delete"]
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<GameResponse> _openGames = [];
    private List<GameResponse> _myActiveGames = [];
    private bool _loadingOpen = true;
    private bool _loadingActive = true;
    private bool _showJoinByCode;
    private bool _showDeleteDialog;
    private bool _deletingGame;
    private string _inviteCode = "";
    private GameResponse? _gameToDelete;

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadOpenGamesAsync(), LoadMyGamesAsync());
    }

    private async Task LoadOpenGamesAsync()
    {
        _loadingOpen = true;
        try { _openGames = await Api.ListGamesAsync("Waiting", true); }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _loadingOpen = false; }
    }

    private async Task LoadMyGamesAsync()
    {
        _loadingActive = true;
        try
        {
            var all = await Api.ListGamesAsync();
            _myActiveGames = all
                .Where(g => g.Players.Any(p => p.Name == Auth.DisplayName))
                .OrderByDescending(g => g.CreatedAt)
                .ToList();
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _loadingActive = false; }
    }

    private async Task JoinGameAsync(Guid gameId)
    {
        try
        {
            var request = new JoinGameRequest(Auth.AccountToken ?? "", Auth.DisplayName ?? "", null, null);
            await Api.JoinGameAsync(gameId, request);
            Snackbar.Add(T["games_joined"], Severity.Success);
            Nav.NavigateTo($"/games/{gameId}/lobby");
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
    }

    private void ShowJoinByCode() => _showJoinByCode = true;

    private async Task JoinByCodeAsync()
    {
        try
        {
            var all = await Api.ListGamesAsync("Waiting");
            var game = all.FirstOrDefault(g => g.InviteCode == _inviteCode.Trim().ToUpper());
            if (game is null)
            {
                Snackbar.Add(T["games_invite_not_found"], Severity.Warning);
                return;
            }
            var request = new JoinGameRequest(Auth.AccountToken ?? "", Auth.DisplayName ?? "", null, _inviteCode.Trim().ToUpper());
            await Api.JoinGameAsync(game.Id, request);
            Snackbar.Add(T["games_joined"], Severity.Success);
            _showJoinByCode = false;
            Nav.NavigateTo($"/games/{game.Id}/lobby");
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
    }

    private void ConfirmDelete(GameResponse game)
    {
        _gameToDelete = game;
        _showDeleteDialog = true;
    }

    private void CloseDeleteDialog()
    {
        _showDeleteDialog = false;
        _gameToDelete = null;
    }

    private async Task DeleteGameAsync()
    {
        if (_gameToDelete is null)
            return;

        _deletingGame = true;
        try
        {
            await Api.DeleteGameAsync(_gameToDelete.Id);
            Snackbar.Add(T["games_deleted"], Severity.Success);
            CloseDeleteDialog();
            await Task.WhenAll(LoadOpenGamesAsync(), LoadMyGamesAsync());
        }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _deletingGame = false; }
    }

    private void GoToGame(GameResponse g)
    {
        if (g.Status == GameStatus.Finished)
            Nav.NavigateTo($"/games/{g.Id}/result");
        else if (g.Status == GameStatus.Active)
            Nav.NavigateTo($"/games/{g.Id}");
        else
            Nav.NavigateTo($"/games/{g.Id}/lobby");
    }

    private static string ResourceColorHex(int pct) => pct > 60 ? "#5ECDB0" : pct > 30 ? "#FFB74D" : "#F06292";
    private static Color ResourceColor(int pct) => pct > 60 ? Color.Success : pct > 30 ? Color.Warning : Color.Error;
}
