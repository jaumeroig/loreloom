@page "/login"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<div class="hero-section">
    <MudCard Class="auth-card" Style="width: 420px; max-width: 95vw;">
        <MudCardContent Class="pa-6">
            <div class="text-center mb-6">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="letter-spacing:0.04em;">LoreLoom</MudText>
                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mt-1">Welcome back, adventurer</MudText>
            </div>
            <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                          InputType="InputType.Email" Class="mb-4" Required="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                          InputType="InputType.Password" Class="mb-1" Required="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                          OnKeyDown="OnKeyDown" />
            <div class="d-flex justify-end mb-3">
                <MudLink Href="/forgot-password" Typo="Typo.body2" Color="Color.Secondary">
                    Forgot password?
                </MudLink>
            </div>

            @if (_showResendVerification)
            {
                <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-2">
                    Your account still needs email verification.
                    <MudLink OnClick="ResendVerificationAsync" Color="Color.Warning" Style="cursor:pointer;text-decoration:underline;">
                        Resend verification email
                    </MudLink>
                </MudAlert>
            }
        </MudCardContent>
        <MudCardActions Class="d-flex flex-column pa-6 pt-0">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                       OnClick="LoginAsync" Disabled="_loading"
                       Style="border-radius:12px;height:48px;font-weight:600;">
                @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                Log In
            </MudButton>
            <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center" Style="color:#9A97B0;">
                Don't have an account?
                <MudLink Href="/register" Color="Color.Secondary">Sign up</MudLink>
            </MudText>
        </MudCardActions>
    </MudCard>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private bool _loading;
    private bool _resendingVerification;
    private bool _showResendVerification;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await LoginAsync();
    }

    private async Task LoginAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add("Please fill in all fields.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            _showResendVerification = false;
            var result = await Api.LoginAsync(new LoginRequest(_email, _password));
            if (result?.Jwt is not null)
            {
                await Auth.LoginAsync(result.Jwt, result.DisplayName, result.Email, result.Token, result.EmailVerified);
                Nav.NavigateTo("/games");
            }
        }
        catch (HttpRequestException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.Forbidden)
            {
                _showResendVerification = true;
                Snackbar.Add("Please verify your email address before logging in. Check your inbox.", Severity.Warning);
            }
            else if (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
                Snackbar.Add("Invalid email or password.", Severity.Error);
            else
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task ResendVerificationAsync()
    {
        if (_resendingVerification)
            return;

        if (string.IsNullOrWhiteSpace(_email))
        {
            Snackbar.Add("Enter your email address first.", Severity.Warning);
            return;
        }

        _resendingVerification = true;
        try
        {
            await Api.ResendVerificationAsync(_email);
            Snackbar.Add("Verification email sent. Check your inbox.", Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _resendingVerification = false;
        }
    }
}
