@page "/profile"
@inject AuthService Auth
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T

<MudText Typo="Typo.h4" Class="mb-6">@T["profile_title"]</MudText>

<MudGrid>
    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">@T["profile_account"]</MudText>
                <MudTextField @bind-Value="_displayName" Label="@(T["profile_nickname"])"
                              Variant="Variant.Outlined" Class="mb-4"
                              Counter="50" MaxLength="50"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveNickname"
                           Disabled="_savingNickname || _displayName == Auth.DisplayName"
                           Class="mb-4" Style="border-radius:12px;">
                    @if (_savingNickname) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @T["profile_save_nickname"]
                </MudButton>
                <MudTextField Value="@Auth.Email" Label="@(T["common_email"])" ReadOnly="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">@T["profile_change_password"]</MudText>
                <MudTextField @bind-Value="_currentPassword" Label="@(T["profile_current_password"])"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_newPassword" Label="@(T["profile_new_password"])"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              HelperText="@(T["profile_password_helper"])"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_confirmNewPassword" Label="@(T["profile_confirm_new_password"])"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePasswordAsync"
                           Disabled="_changingPassword" Style="border-radius:12px;">
                    @if (_changingPassword) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @T["profile_change_password_button"]
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">@T["profile_preferences"]</MudText>
                <MudSelect T="string" @bind-Value="_language" Label="@(T["profile_app_language"])"
                           Variant="Variant.Outlined" Class="mb-4"
                           AnchorOrigin="Origin.BottomCenter"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Language">
                    <MudSelectItem Value="@AppCultures.Catalan">@T["culture_ca-ES"]</MudSelectItem>
                    <MudSelectItem Value="@AppCultures.Spanish">@T["culture_es-ES"]</MudSelectItem>
                    <MudSelectItem Value="@AppCultures.English">@T["culture_en-US"]</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePreferences"
                           Style="border-radius:12px;">
                    @T["profile_save_preferences"]
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _language = AppCultures.DefaultCulture;
    private string _displayName = "";
    private bool _savingNickname;

    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmNewPassword = "";
    private bool _changingPassword;

    protected override void OnInitialized()
    {
        _language = Auth.Language;
        _displayName = Auth.DisplayName ?? "";
    }

    private async Task SaveNickname()
    {
        var normalizedDisplayName = _displayName.Trim();

        if (string.IsNullOrWhiteSpace(normalizedDisplayName))
        {
            Snackbar.Add(T["profile_nickname_empty"], Severity.Warning);
            return;
        }

        if (normalizedDisplayName.Length < 3)
        {
            Snackbar.Add(T["profile_nickname_min"], Severity.Warning);
            return;
        }

        _savingNickname = true;
        try
        {
            var result = await Api.UpdateDisplayNameAsync(new UpdateDisplayNameRequest(normalizedDisplayName));
            if (result is null)
            {
                Snackbar.Add(T["profile_nickname_update_failed"], Severity.Error);
                return;
            }

            await Auth.UpdateSessionAsync(result);
            _displayName = result.DisplayName;
            Snackbar.Add(T["profile_nickname_updated"], Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error);
        }
        finally
        {
            _savingNickname = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add(T["profile_fill_password_fields"], Severity.Warning);
            return;
        }

        if (_newPassword != _confirmNewPassword)
        {
            Snackbar.Add(T["profile_new_passwords_no_match"], Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            Snackbar.Add(T["profile_password_min"], Severity.Warning);
            return;
        }

        _changingPassword = true;
        try
        {
            var result = await Api.ChangePasswordAsync(
                new ChangePasswordRequest(_currentPassword, _newPassword, _confirmNewPassword));

            if (result is not null)
                await Auth.UpdateSessionAsync(result);

            _currentPassword = "";
            _newPassword = "";
            _confirmNewPassword = "";
            Snackbar.Add(T["profile_password_changed"], Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.StatusCode == System.Net.HttpStatusCode.BadRequest
                ? T["profile_invalid_password"]
                : T.Format("common_error", ex.Message), Severity.Error);
        }
        finally
        {
            _changingPassword = false;
        }
    }

    private async Task SavePreferences()
    {
        await Auth.SetLanguageAsync(_language);
        var result = await Api.UpdateCultureAsync(new UpdateCultureRequest(_language));
        if (result is not null)
            await Auth.UpdateSessionAsync(result);
        Snackbar.Add(T["profile_preferences_saved"], Severity.Success);
    }
}
