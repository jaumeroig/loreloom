@page "/profile"
@inject AuthService Auth
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-6">Profile</MudText>

<MudGrid>
    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">Account</MudText>
                <MudTextField @bind-Value="_displayName" Label="Nickname"
                              Variant="Variant.Outlined" Class="mb-4"
                              Counter="50" MaxLength="50"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Person" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveNickname"
                           Disabled="_savingNickname || _displayName == Auth.DisplayName"
                           Class="mb-4" Style="border-radius:12px;">
                    @if (_savingNickname) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Save Nickname
                </MudButton>
                <MudTextField Value="@Auth.Email" Label="Email" ReadOnly="true"
                              Variant="Variant.Outlined"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">Change Password</MudText>
                <MudTextField @bind-Value="_currentPassword" Label="Current Password"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_newPassword" Label="New Password"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              HelperText="At least 8 characters"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_confirmNewPassword" Label="Confirm New Password"
                              InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ChangePasswordAsync"
                           Disabled="_changingPassword" Style="border-radius:12px;">
                    @if (_changingPassword) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Change Password
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>

    <MudItem xs="12" sm="6">
        <MudCard Elevation="0" Class="glass-card">
            <MudCardContent Class="pa-5">
                <MudText Typo="Typo.h6" Class="mb-4">Preferences</MudText>
                <MudSelect T="string" @bind-Value="_language" Label="Game Language"
                           Variant="Variant.Outlined" Class="mb-4"
                           AnchorOrigin="Origin.BottomCenter"
                           Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Language">
                    <MudSelectItem Value="@("English")">English</MudSelectItem>
                    <MudSelectItem Value="@("Català")">Català</MudSelectItem>
                    <MudSelectItem Value="@("Español")">Español</MudSelectItem>
                    <MudSelectItem Value="@("Français")">Français</MudSelectItem>
                    <MudSelectItem Value="@("Deutsch")">Deutsch</MudSelectItem>
                    <MudSelectItem Value="@("Italiano")">Italiano</MudSelectItem>
                    <MudSelectItem Value="@("Português")">Português</MudSelectItem>
                    <MudSelectItem Value="@("日本語")">日本語</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePreferences"
                           Style="border-radius:12px;">
                    Save Preferences
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private string _language = "English";
    private string _displayName = "";
    private bool _savingNickname;

    private string _currentPassword = "";
    private string _newPassword = "";
    private string _confirmNewPassword = "";
    private bool _changingPassword;

    protected override void OnInitialized()
    {
        _language = Auth.Language;
        _displayName = Auth.DisplayName ?? "";
    }

    private async Task SaveNickname()
    {
        var normalizedDisplayName = _displayName.Trim();

        if (string.IsNullOrWhiteSpace(normalizedDisplayName))
        {
            Snackbar.Add("Nickname cannot be empty.", Severity.Warning);
            return;
        }

        if (normalizedDisplayName.Length < 3)
        {
            Snackbar.Add("Nickname must be at least 3 characters.", Severity.Warning);
            return;
        }

        _savingNickname = true;
        try
        {
            var result = await Api.UpdateDisplayNameAsync(new UpdateDisplayNameRequest(normalizedDisplayName));
            if (result is null)
            {
                Snackbar.Add("Could not update nickname.", Severity.Error);
                return;
            }

            await Auth.UpdateSessionAsync(result);
            _displayName = result.DisplayName;
            Snackbar.Add("Nickname updated.", Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingNickname = false;
        }
    }

    private async Task ChangePasswordAsync()
    {
        if (string.IsNullOrWhiteSpace(_currentPassword) || string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("Please fill in all password fields.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmNewPassword)
        {
            Snackbar.Add("New passwords do not match.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("New password must be at least 8 characters.", Severity.Warning);
            return;
        }

        _changingPassword = true;
        try
        {
            var result = await Api.ChangePasswordAsync(
                new ChangePasswordRequest(_currentPassword, _newPassword, _confirmNewPassword));

            if (result is not null)
                await Auth.UpdateSessionAsync(result);

            _currentPassword = "";
            _newPassword = "";
            _confirmNewPassword = "";
            Snackbar.Add("Password changed successfully.", Severity.Success);
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.StatusCode == System.Net.HttpStatusCode.BadRequest
                ? "Current password is incorrect or new password is invalid."
                : $"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _changingPassword = false;
        }
    }

    private async Task SavePreferences()
    {
        await Auth.SetLanguageAsync(_language);
        Snackbar.Add("Preferences saved.", Severity.Success);
    }
}
