@page "/ranking"
@inject LoreLoomApiClient Api
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T

<MudText Typo="Typo.h4" Class="mb-6">@T["ranking_title"]</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_ranking.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        @T["ranking_empty"]
    </MudAlert>
}
else
{
    <MudCard Elevation="0" Class="glass-card">
        <MudTable Items="_ranking" Hover="true" Elevation="0" Dense="true"
                  Style="background:transparent;">
            <HeaderContent>
                <MudTh>@T["ranking_rank"]</MudTh>
                <MudTh>@T["ranking_player"]</MudTh>
                <MudTh>@T["ranking_character"]</MudTh>
                <MudTh>@T["ranking_points"]</MudTh>
                <MudTh>@T["ranking_games"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @if (context.Rank == 1)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Filled"
                                 Style="font-weight:700;">1st</MudChip>
                    }
                    else if (context.Rank == 2)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Filled"
                                 Style="font-weight:700;">2nd</MudChip>
                    }
                    else if (context.Rank == 3)
                    {
                        <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled"
                                 Style="font-weight:700;">3rd</MudChip>
                    }
                    else
                    {
                        <MudText Style="color:#9A97B0;">@context.Rank</MudText>
                    }
                </MudTd>
                <MudTd><b>@context.PlayerName</b></MudTd>
                <MudTd Style="color:#9A97B0;">@(context.CharacterName ?? "—")</MudTd>
                <MudTd>
                    <MudText Color="Color.Primary" Style="font-weight:600;">@context.TotalPoints</MudText>
                </MudTd>
                <MudTd Style="color:#9A97B0;">@context.GamesPlayed</MudTd>
            </RowTemplate>
        </MudTable>
    </MudCard>
}

@code {
    private List<RankingEntry> _ranking = [];
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try { _ranking = await Api.GetRankingAsync(); }
        catch (Exception ex) { Snackbar.Add(T.Format("common_error", ex.Message), Severity.Error); }
        finally { _loading = false; }
    }
}
