@page "/register"
@inject LoreLoomApiClient Api
@inject AuthService Auth
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IAppTextLocalizer T

<div class="hero-section">
    <MudCard Class="auth-card" Style="width: 420px; max-width: 95vw;">
        <MudCardContent Class="pa-6">
            <div class="text-center mb-6">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="letter-spacing:0.04em;">LoreLoom</MudText>
                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mt-1">@T["register_begin_adventure"]</MudText>
            </div>

            @if (_registered)
            {
                <MudAlert Severity="Severity.Success" Class="mb-2">
                    @((MarkupString)T.Format("register_account_created", $"<strong>{_email}</strong>"))
                </MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           Href="/login" Style="border-radius:12px;margin-top:8px;">
                    @T["register_go_to_login"]
                </MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_email" Label="@(T["common_email"])" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-4" Required="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                <MudTextField @bind-Value="_displayName" Label="@(T["register_nickname"])" Variant="Variant.Outlined"
                              Class="mb-4" Required="true" Counter="50" MaxLength="50"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Badge"
                              HelperText="@(T["register_nickname_helper"])" />
                <MudTextField @bind-Value="_password" Label="@(T["common_password"])" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-4" Required="true"
                              HelperText="@(T["register_password_min"])"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_confirmPassword" Label="@(T["register_confirm_password"])" Variant="Variant.Outlined"
                              InputType="InputType.Password"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                              OnKeyDown="OnKeyDown" />
            }
        </MudCardContent>

        @if (!_registered)
        {
            <MudCardActions Class="d-flex flex-column pa-6 pt-2">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="RegisterAsync" Disabled="_loading"
                           Style="border-radius:12px;height:48px;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @T["register_create_account"]
                </MudButton>
                <MudText Typo="Typo.body2" Class="mt-4" Align="Align.Center" Style="color:#9A97B0;">
                    @T["register_have_account"]
                    <MudLink Href="/login" Color="Color.Secondary">@T["common_log_in"]</MudLink>
                </MudText>
            </MudCardActions>
        }
    </MudCard>
</div>

@code {
    private string _email = "";
    private string _displayName = "";
    private string _password = "";
    private string _confirmPassword = "";
    private bool _loading;
    private bool _registered;

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await RegisterAsync();
    }

    private async Task RegisterAsync()
    {
        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_displayName) || string.IsNullOrWhiteSpace(_password))
        {
            Snackbar.Add(T["register_fill_all_fields"], Severity.Warning);
            return;
        }

        if (_password != _confirmPassword)
        {
            Snackbar.Add(T["register_passwords_no_match"], Severity.Warning);
            return;
        }

        if (_password.Length < 8)
        {
            Snackbar.Add(T["register_password_min"], Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            var result = await Api.RegisterAsync(new RegisterRequest(_email, _displayName, _password));
            if (result is not null)
            {
                _registered = true;
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add(ex.StatusCode == System.Net.HttpStatusCode.Conflict
                ? T["api_email_registered"]
                : T.Format("common_error", ex.Message), Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
