@page "/reset-password"
@inject LoreLoomApiClient Api
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<div class="hero-section">
    <MudCard Class="auth-card" Style="width: 420px; max-width: 95vw;">
        <MudCardContent Class="pa-6">
            <div class="text-center mb-6">
                <MudText Typo="Typo.h4" Color="Color.Primary" Style="letter-spacing:0.04em;">LoreLoom</MudText>
                <MudText Typo="Typo.body2" Style="color:#9A97B0;" Class="mt-1">Choose a new password</MudText>
            </div>

            @if (_invalidLink)
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">
                    This reset link is invalid or has expired. Please request a new one.
                </MudAlert>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true"
                           Href="/forgot-password" Style="border-radius:12px;">
                    Request New Link
                </MudButton>
            }
            else if (_success)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4">
                    Password reset successfully! You can now log in with your new password.
                </MudAlert>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Href="/login" Style="border-radius:12px;">
                    Go to Login
                </MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_newPassword" Label="New Password" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-4" Required="true"
                              HelperText="At least 8 characters"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudTextField @bind-Value="_confirmPassword" Label="Confirm New Password" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-4" Required="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                              OnKeyDown="OnKeyDown" />
            }
        </MudCardContent>

        @if (!_invalidLink && !_success)
        {
            <MudCardActions Class="pa-6 pt-0">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           OnClick="ResetAsync" Disabled="_loading"
                           Style="border-radius:12px;height:48px;font-weight:600;">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Reset Password
                </MudButton>
            </MudCardActions>
        }
    </MudCard>
</div>

@code {
    private string _token = "";
    private string _newPassword = "";
    private string _confirmPassword = "";
    private bool _loading;
    private bool _success;
    private bool _invalidLink;

    protected override void OnInitialized()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _token = query["token"] ?? "";

        if (string.IsNullOrWhiteSpace(_token))
            _invalidLink = true;
    }

    private async Task OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ResetAsync();
    }

    private async Task ResetAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPassword))
        {
            Snackbar.Add("Please enter a new password.", Severity.Warning);
            return;
        }

        if (_newPassword != _confirmPassword)
        {
            Snackbar.Add("Passwords do not match.", Severity.Warning);
            return;
        }

        if (_newPassword.Length < 8)
        {
            Snackbar.Add("Password must be at least 8 characters.", Severity.Warning);
            return;
        }

        _loading = true;
        try
        {
            await Api.ResetPasswordAsync(new ResetPasswordRequest(_token, _newPassword, _confirmPassword));
            _success = true;
        }
        catch (HttpRequestException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.BadRequest)
                _invalidLink = true;
            else
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _loading = false;
        }
    }
}
